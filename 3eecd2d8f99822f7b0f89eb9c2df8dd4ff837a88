else\n        # Set phase back to generating to resume\n        python3 - \"$state_file\" <<'PYEOF'\nimport json, sys\npath = sys.argv[1]\nwith open(path) as f:\n    s = json.load(f)\ns[\"phase\"] = \"generating\"\ns[\"last_error\"] = None\nwith open(path, \"w\") as f:\n    json.dump(s, f, indent=2)\nPYEOF\n        echo \"State reset to 'generating'.\"\n    fi\n\n    cmd_run \"$name\"\n}\n\ncmd_watchdog() {\n    local action=\"${1:-status}\"\n\n    if [[ \"$action\" == \"install\" ]]; then\n        local name=\"${2:-}\"\n        if [[ -z \"$name\" ]]; then\n            echo \"Usage: mjolnir watchdog install <project-name>\"\n            exit 1\n        fi\n        local project_dir\n        project_dir=\"$(resolve_project \"$name\")\"\n        local abs_project\n        abs_project=\"$(cd \"$project_dir\" && pwd)\"\n        local cron_line=\"*/5 * * * * '${SCRIPT_DIR}/mjolnir-watchdog.sh' '${abs_project}'\"\n\n        # Check if already installed\n        if crontab -l 2>/dev/null | grep -qF \"$abs_project\"; then\n            echo \"Watchdog already installed for '${name}'\"\n            return\n        fi\n\n        (crontab -l 2>/dev/null; echo \"$cron_line\") | crontab -\n        echo \"Watchdog installed for '${name}' (checks every 5 minutes)\"\n\n    elif [[ \"$action\" == \"remove\" ]]; then\n        local name=\"${2:-}\"\n        if [[ -z \"$name\" ]]; then\n            echo \"Usage: mjolnir watchdog remove <project-name>\"\n            exit 1\n        fi\n        local project_dir\n        project_dir=\"$(resolve_project \"$name\")\"\n        local abs_project\n        abs_project=\"$(cd \"$project_dir\" && pwd)\"\n\n        crontab -l 2>/dev/null | grep -vF \"$abs_project\" | crontab -\n        echo \"Watchdog removed for '${name}'\"\n\n    else\n        echo \"Installed watchdogs:\"\n        crontab -l 2>/dev/null | grep \"mjolnir-watchdog\" || echo \"  (none)\"\n    fi\n}\n\ncmd_help() {\n    cat <<'EOF'\nMjolnir — Autonomous Coding Harness\n\nUSAGE:\n  