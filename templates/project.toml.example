# Mjolnir Project Configuration
# Copy this file to workspace/<project-name>/project.toml and customize.
#
# Required fields are uncommented. Optional fields are commented with defaults.
# Generated code is written to ./<name>/ inside the project directory.

# model = ""               # Claude model for all agents (e.g. "claude-haiku-4-5-20251001")
                            # Empty = use claude CLI default. Override with MJOLNIR_MODEL env var.

[project]
name = "my-app"
description = "A brief description of what to build"

goals = [
    "Build a web application with ...",
    "Include user authentication",
    "Deploy-ready with Docker",
]

tech_stack = "TypeScript, Fastify, React, Vite, Tailwind CSS, better-sqlite3"

# constraints = []

[planning]
# mode = "interactive"    # "interactive" or "auto" (headless for VPS/overnight)

[scoring]
# [scoring.weights]
# design_quality = 0.35
# originality = 0.25
# craft = 0.25
# functionality = 0.15

# [scoring.thresholds]
# design_quality = 7
# originality = 5
# craft = 6
# functionality = 6

[budget]
# max_retries = 3         # Max retries per sprint before halting
# max_sprints = 0         # 0 = let planner decide
# budget_per_sprint = 0   # Cost tracking only (not enforced)

# [notifications]
# ntfy_topic = "mjolnir-harness"    # override with MJOLNIR_NTFY_TOPIC env var
# ntfy_server = "https://ntfy.sh"   # override with MJOLNIR_NTFY_SERVER env var
