block                 = \"10.0.1.0/24\"\n  route_table_id             = oci_core_route_table.mjolnir.id\n  security_list_ids          = [oci_core_security_list.mjolnir.id]\n  prohibit_public_ip_on_vnic = false\n  dns_label                  = \"mjolnir\"\n}\n",
