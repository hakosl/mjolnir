            "content": "#!/usr/bin/env bash\n# Mjolnir CLI — Simple interface for the autonomous coding harness.\n# Usage: mjolnir <command> [args]\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nWORKSPACE_DIR=\"${MJOLNIR_WORKSPACE:-${SCRIPT_DIR}/workspace}\"\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\ndie() { echo \"Error: $1\" >&2; exit 1; }\n\n# Resolve project dir from name or path\nresolve_project() {\n    local name=\"$1\"\n    if [[ -d \"$name\" && -f \"$name/project.toml\" ]]; then\n        echo \"$name\"\n    elif [[ -d \"${WORKSPACE_DIR}/${name}\" ]]; then\n        echo \"${WORKSPACE_DIR}/${name}\"\n    else\n        die \"Project '${name}' not found. Run 'mjolnir list' to see projects.\"\n    fi\n}\n\n# Get tmux session name for a project\nsession_name() {\n    local project_dir=\"$1\"\n    local abs_dir\n    abs_dir=\"$(cd \"$project_dir\" && pwd)\"\n    echo \"mjolnir-$(echo \"$abs_dir\" | md5sum 2>/dev/null | cut -c1-8 || echo \"$abs_dir\" | md5 -q 2>/dev/null | cut -c1-8 || basename \"$abs_dir\")\"\n}\n\njson_field() {\n    local file=\"$1\" field=\"$2\" default=\"${3:-}\"\n    python3 - \"$file\" \"$field\" \"$default\" <<'PYEOF'\nimport json, sys\ntry:\n    with open(sys.argv[1]) as f:\n        data = json.load(f)\n    val = data.get(sys.argv[2], sys.argv[3])\n    print(val if val is not None else sys.argv[3])\nexcept (KeyError, json.JSONDecodeError, FileNotFoundError):\n    print(sys.argv[3])\nPYEOF\n}\n\n# ---------------------------------------------------------------------------\n# Commands\n# ---------------------------------------------------------------------------\n\ncmd_new() {\n    local name=\"${1:-}\"\n    if [[ -z \"$name\" ]]; then\n        echo \"Usage: mjolnir new <project-name>\"\n        exit 1\n    fi\n\n    local project_dir=\"${WORKSPACE_DIR}/${name}\"\n    if [[ -d \"$project_dir\" ]]; then\n        die \"Project '${name}' already exists at ${project_dir}\"\n    fi\n\n    mkdir -p \"$project_dir\"\n    cp \"${SCRIPT_DIR}/templates/project.toml.example\" \"${project_dir}/project.toml\"\n\n    echo \"Created project: ${project_dir}\"\n    echo \"\"\n    echo \"Next steps:\"\n    echo \"  1. Edit config:  mjolnir edit ${name}\"\n    echo \"  2. Start build:  mjolnir run ${name}\"\n}\n\ncmd_edit() {\n    local name=\"${1:-}\"\n    if [[ -z \"$name\" ]]; then\n        echo \"Usage: mjolnir edit <project-name>\"\n        exit 1\n    fi\n    local project_dir\n    project_dir=\"$(resolve_project \"$name\")\"\n    \"${EDITOR:-nano}\" \"${project_dir}/project.toml\"\n}\n\ncmd_run() {\n    local name=\"${1:-}\"\n    if [[ -z \"$name\" ]]; then\n        echo \"Usage: mjolnir run <project-name>\"\n        exit 1\n    fi\n    local project_dir\n    project_dir=\"$(resolve_project \"$name\")\"\n    local session\n    session=\"$(session_name \"$project_dir\")\"\n\n    # Check if already running\n    if tmux has-session -t \"$session\" 2>/dev/null; then\n        echo \"Already running. Attaching...\"\n        tmux attach -t \"$session\"\n        return\n    fi\n\n    echo \"Starting Mjolnir for '${name}' in tmux session '${session}'...\"\n    tmux new-session -d -s \"$session\" \\\n        \"bash '${SCRIPT_DIR}/mjolnir.sh' '${project_dir}' 2>&1 | tee -a '${project_dir}/mjolnir-tmux.log'\"\n    echo \"Running in background. Use:\"\n    echo \"  mjolnir attach ${name}   — attach to live session\"\n    echo \"  mjolnir status ${name}   — check progress\"\n    echo \"  mjolnir logs ${name}     — tail structured logs\"\n}\n\ncmd_attach() {\n    local name=\"${1:-}\"\n    if [[ -z \"$name\" ]]; then\n        echo \"Usage: mjolnir attach <project-name>\"\n        exit 1\n    fi\n    local project_dir\n    project_dir=\"$(resolve_project \"$name\")\"\n    local session\n    session=\"$(session_name \"$project_dir\")\"\n\n    if ! tmux has-session -t \"$session\" 2>/dev/null; then\n        die \"No running session for '${name}'. Start with: mjolnir run ${name}\"\n    fi\n    tmux attach -t \"$session\"\n}\n\ncmd_status() {\n    local name=\"${1:-}\"\n\n    # No arg: show all projects\n    if [[ -z \"$name\" ]]; then\n        echo \"MJOLNIR PROJECTS\"\n        echo \"================\"\n        echo \"\"\n        if [[ ! -d \"$WORKSPACE_DIR\" ]]; then\n            echo \"No workspace yet. Run: mjolnir new <name>\"\n            return\n        fi\n        local found=false\n        for dir in \"${WORKSPACE_DIR}\"/*/; do\n            [[ -f \"${dir}project.toml\" ]] || continue\n            found=true\n            local pname\n            pname=\"$(basename \"$dir\")\"\n            local state_file=\"${dir}state.json\"\n            local phase=\"idle\"\n            local sprint=\"0\"\n            local total=\"0\"\n            local running=\"no\"\n\n            if [[ -f \"$state_file\" ]]; then\n                phase=\"$(json_field \"$state_file\" \"phase\" \"idle\")\"\n                sprint=\"$(json_field \"$state_file\" \"sprint\" \"0\")\"\n                total=\"$(json_field \"$state_file\" \"total_sprints\" \"0\")\"\n            fi\n\n            local session\n            session=\"$(session_name \"$dir\")\"\n            if tmux has-session -t \"$session\" 2>/dev/null; then\n                running=\"yes\"\n            fi\n\n            printf \"  %-20s  phase=%-12s  sprint=%s/%s  running=%s\\n\" \\\n                \"$pname\" \"$phase\" \"$sprint\" \"$total\" \"$running\"\n        done\n        if [[ \"$found\" == \"false\" ]]; then\n            echo \"  No projects yet. Run: mjolnir new <name>\"\n        fi\n        return\n    fi\n\n    # Specific project\n    local project_dir\n    project_dir=\"$(resolve_project \"$name\")\"\n    local state_file=\"${project_dir}/state.json\"\n\n    if [[ ! -f \"$state_file\" ]]; then\n        echo \"Project '${name}': not started yet\"\n        echo \"Run: mjolnir run ${name}\"\n        return\n    fi\n\n    echo \"PROJECT: ${name}\"\n    echo \"---\"\n    python3 - \"$state_file\" <<'PYEOF'\nimport json, sys, time\nwith open(sys.argv[1]) as f:\n    s = json.load(f)\nphase = s[\"phase\"]\nsprint = s[\"sprint\"]\ntotal = s[\"total_sprints\"]\nattempt = s[\"attempt\"]\ncosts = s[\"costs\"]\ntotal_cost = sum(costs.values())\nupdated = time.strftime(\"%Y-%m-%d %H:%M:%S\", time.localtime(s[\"updated_at\"]))\n\nprint(f\"  Phase:    {phase}\")\nprint(f\"  Sprint:   {sprint}/{total} (attempt {attempt})\")\nprint(f\"  Cost:     ${total_cost:.2f} (planner: ${costs.get('planner',0):.2f}, generator: ${costs.get('generator',0):.2f}, evaluator: ${costs.get('evaluator',0):.2f})\")\nprint(f\"  Updated:  {updated}\")\n\nif s.get(\"rate_limit_until\"):\n    rl = time.strftime(\"%Y-%m-%d %H:%M:%S\", time.localtime(s[\"rate_limit_until\"]))\n    print(f\"  Rate limited until: {rl}\")\nif s.get(\"last_error\"):\n    print(f\"  Last error: {s['last_error']}\")\nPYEOF\n\n    # Check if running\n    local session\n    session=\"$(session_name \"$project_dir\")\"\n    if tmux has-session -t \"$session\" 2>/dev/null; then\n        echo \"  Running:  yes (tmux: ${session})\"\n    else\n        echo \"  Running:  no\"\n    fi\n\n    # Show latest eval scores if available\n    local latest_eval\n    latest_eval=\"$(ls -t \"${project_dir}\"/sprints/*/eval_report.json 2>/dev/null | head -1 || true)\"\n    if [[ -n \"$latest_eval\" ]]; then\n        echo \"\"\n        echo \"LATEST EVALUATION:\"\n        python3 - \"$latest_eval\" <<'PYEOF'\nimport json, sys\nwith open(sys.argv[1]) as f:\n    r = json.load(f)\nscores = r.get(\"scores\", {})\npassed = r.get(\"passed\", False)\nstatus = \"PASSED\" if passed else \"FAILED\"\nprint(f\"  Sprint {r.get('sprint','?')} attempt {r.get('attempt','?')}: {status}\")\nfor k, v in scores.items():\n    print(f\"    {k}: {v}/10\")\nfeedback = r.get(\"feedback\", \"\")\nif feedback:\n    print(f\"  Feedback: {feedback[:20